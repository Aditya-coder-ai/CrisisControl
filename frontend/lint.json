main className=\"flex-1 p-6 md:p-12 flex flex-col items-center justify-center space-y-12\">\n        \n        {/* Voice Input Section */}\n        <div className=\"w-full max-w-lg text-center space-y-6\">\n          <h2 className=\"text-3xl font-extrabold text-slate-800 dark:text-white\">What is happening?</h2>\n          <p className=\"text-xl text-slate-600 dark:text-slate-300\">Tap to describe the emergency or request help instantly.</p>\n          \n          <button \n            onClick={() => setIsRecording(!isRecording)}\n            className={`w-40 h-40 mx-auto rounded-full flex items-center justify-center shadow-xl transition-all duration-300 ${\n              isRecording \n                ? 'bg-red-500 animate-pulse ring-8 ring-red-500/30' \n                : 'bg-white dark:bg-slate-800 hover:scale-105 border-4 border-red-500'\n            }`}\n          >\n            <Mic className={`w-16 h-16 ${isRecording ? 'text-white' : 'text-red-500'}`} />\n          </button>\n          \n          <div className=\"h-8\">\n            {isRecording && <p className=\"text-red-500 font-semibold animate-pulse\">Recording... Tap to stop.</p>}\n          </div>\n        </div>\n\n        {/* Location Section */}\n        <div className=\"w-full max-w-lg bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-lg border border-slate-100 dark:border-slate-700\">\n          <div className=\"flex items-center justify-between mb-4\">\n            <h3 className=\"text-xl font-bold text-slate-800 dark:text-white flex items-center gap-2\">\n              <MapPin className=\"text-blue-500\" /> Current Location\n            </h3>\n            <span className=\"bg-blue-100 text-blue-700 text-sm px-3 py-1 rounded-full font-semibold\">High Accuracy</span>\n          </div>\n          <div className=\"h-48 bg-slate-200 dark:bg-slate-700 rounded-xl relative overflow-hidden group\">\n            {/* Map stub */}\n            <div className=\"absolute inset-0 bg-[url('https://maps.wikimedia.