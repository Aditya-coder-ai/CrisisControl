 className=\"p-6 border-b border-slate-800\">\n          <h1 className=\"text-xl font-bold text-white flex items-center gap-2\">\n            <AlertTriangle className=\"text-red-500\" /> Command Center\n          </h1>\n        </div>\n        <nav className=\"flex-1 p-4 flex flex-col gap-2\">\n          <button className=\"flex items-center gap-3 px-4 py-3 bg-blue-600 text-white rounded-lg font-medium shadow-[0_0_15px_rgba(37,99,235,0.3)]\">\n            <LayoutDashboard className=\"w-5 h-5\" /> Active Incidents\n          </button>\n          <button className=\"flex items-center gap-3 px-4 py-3 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg font-medium transition\">\n            <Users className=\"w-5 h-5\" /> Teams\n          </button>\n          <button className=\"flex items-center gap-3 px-4 py-3 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg font-medium transition\">\n            <MapIcon className=\"w-5 h-5\" /> Live Map\n          </button>\n        </nav>\n      </aside>\n\n      {/* Main Content */}\n      <main className=\"flex-1 flex flex-col h-screen overflow-hidden\">\n        {/* Topbar */}\n        <header className=\"h-16 border-b border-slate-800 bg-slate-900/50 backdrop-blur flex items-center justify-between px-8 shrink-0\">\n          <div className=\"relative w-96\">\n            <Search className=\"w-5 h-5 absolute left-3 top-1/2 -translate-y-1/2 text-slate-500\" />\n            <input \n              type=\"text\" \n              placeholder=\"Search incidents, updates...\" \n              className=\"w-full bg-slate-950 border border-slate-800 rounded-full pl-10 pr-4 py-2 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition\"\n            />\n          </div>\n          <div className=\"flex items-center gap-4\">\n            <button className=\"relative p-2 text-slate-400 hover:text-white transition\">\n              <Bell className=\"w-5 h-5\" />\n              <span className=\"absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full\"></span>\n            </button>\n            <div className=\"w-8 h-8 rounded-full bg-gradient-to-tr from-blue-500 to-purple-500 border-2 border-slate-800\"></div>\n          </div>\n        </header>\n\n        {/* Dashboard Content */}\n        <div className=\"flex-1 overflow-auto p-8\">\n          \n          {/* Stats Row */}\n          <div className=\"grid grid-cols-4 gap-6 mb-8\">\n            {[\n              { label: 'Active Critical', count: 2, icon: AlertTriangle, color: 'text-red-500', bg: 'bg-red-500/10' },\n              { label: 'In Progress', count: 8, icon: Clock, color: 'text-orange-500', bg: 'bg-orange-500/10' },\n              { label: 'Resolved Today', count: 24, icon: CheckCircle, color: 'text-emerald-500', bg: 'bg-emerald-500/10' },\n              { label: 'Available Units', count: 12, icon: Users, color: 'text-blue-500', bg: 'bg-blue-500/10' },\n            ].map((stat, i) => (\n              <div key={i} className=\"bg-slate-900 border border-slate-800 p-6 rounded-2xl flex items-center justify-between\">\n                <div>\n                  <p className=\"text-sm text-slate-400 font-medium\">{stat.label}</p>\n                  <p className=\"text-3xl font-bold text-white mt-1\">{stat.count}</p>\n                </div>\n                <div className={`p-4 rounded-xl ${stat.bg}`}>\n                  <stat.icon className={`w-8 h-8 ${stat.color}`} />\n                </div>\n              </div>\n            ))}\n          </div>\n\n          {/* Incident List */}\n          <div className=\"bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden flex flex-col h-[500px]\">\n            <div className=\"p-6 border-b border-slate-800 flex items-center justify-between\">\n              <h2 className=\"text-lg font-bold text-white\">Incident Queue</h2>\n              <button className=\"flex items-center gap-2 text-sm text-slate-400 hover:text-white transition px-3 py-1.5 border border-slate-700 rounded-lg\">\n                <Filter className=\"w-4 h-4\" /> Filter\n              </button>\n            </div>\n            \n            <div className=\"flex-1 overflow-auto\">\n              <table className=\"w-full text-left border-collapse\">\n                <thead>\n                  <tr className=\"bg-slate-950 text-slate-400 text-sm border-b border-slate-800\">\n                    <th className=\"p-4 font-medium\">ID</th>\n                    <th className=\"p-4 font-medium\">Type</th>\n                    <th className=\"p-4 font-medium\">Severity</th>\n                    <th className=\"p-4 font-medium\">Status</th>\n                    <th className=\"p-4 font-medium\">Location</th>\n                    <th className=\"p-4 font-medium\">Time</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  {mockIncidents.map((inc) => (\n                    <tr key={inc.id} className=\"border-b border-slate-800 hover:bg-slate-800/50 transition cursor-pointer group\">\n                      <td className=\"p-4 font-medium text-white\">{inc.id}</td>\n                      <td className=\"p-4\">{inc.type}</td>\n                      <td className=\"p-4\">\n                        <span className={`inline-flex px-2.5 py-1 rounded-full text-xs font-bold uppercase tracking-wider\n                          ${inc.severity === 'Critical' ? 'bg-red-500/10 text-red-500 border border-red-500/20' : 'bg-orange-500/10 text-orange-400 border border-orange-500/20'}`}>\n                          {inc.severity}\n                        </span>\n                      </td>\n                      <td className=\"p-4 text-slate-300\">{inc.status}</td>\n                      <td className=\"p-4 text-slate-400\">{inc.location}</td>\n                      <td className=\"p-4 text-slate-500 group-hover:text-slate-300\">{inc.time}</td>\n                    </tr>\n                  ))}\n                </tbody>\n              </table>\n            </div>\n          </div>\n\n        </div>\n      </main>\n    </div>\n  );\n}\n","usedDeprecatedRules":[{"ruleId":"no-extra-semi","replacedBy":[]},{"ruleId":"no-mixed-spaces-and-tabs","replacedBy":[]}]},{"filePath":"C:\\Users\\ACER\\OneDrive\\Attachments\\Desktop\\Team\\frontend\\vite.config.ts","messages":[{"ruleId":"react-refresh/only-export-components","message":"Definition for rule 'react-refresh/only-export-components' was not found.","line":1,"column":1,"endLine":1,"endColumn":2,"severity":2,"nodeType":null}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { defineConfig } from 'vite'\nimport react from '@vitejs/plugin-react'\nimport path from 'path'\n\n// https://vitejs.dev/config/\nexport default defineConfig({\n  plugins: [react()],\n  resolve: {\n    alias: {\n      \"@\": path.resolve(__dirname, \"./src\"),\n    },\n  },\n})\n","usedDeprecatedRules":[{"ruleId":"no-extra-semi","replacedBy":[]},{"ruleId":"no-mixed-spaces-and-tabs","replacedBy":[]}]}]
