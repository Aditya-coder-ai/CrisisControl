een w-full bg-slate-900 flex flex-col relative overflow-hidden\">\n      \n      {/* Map Background Stub */}\n      <div className=\"absolute inset-0 z-0 bg-slate-800\">\n        <div className=\"w-full h-full bg-[url('https://maps.wikimedia.org/osm-intl/13/4093/2724.png')] bg-cover bg-center opacity-30 mix-blend-luminosity\"></div>\n      </div>\n\n      {/* Top HUD */}\n      <div className=\"z-10 p-4 flex justify-between items-start pointer-events-none\">\n        <div className=\"pointer-events-auto bg-slate-900/90 backdrop-blur border border-slate-700 p-3 rounded-2xl shadow-2xl flex items-center gap-4\">\n          <div className=\"w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center border-2 border-blue-400\">\n            <Radio className=\"text-white w-5 h-5\" />\n          </div>\n          <div>\n            <h2 className=\"text-white font-bold tracking-wider\">UNIT-04 (ACTIVE)</h2>\n            <p className=\"text-blue-400 text-xs font-mono\">SECTOR 7-G ΓÇó ONLINE</p>\n          </div>\n        </div>\n\n        <div className=\"pointer-events-auto flex flex-col gap-3\">\n          <button className=\"bg-slate-900/90 backdrop-blur border border-slate-700 p-3 rounded-full text-slate-300 hover:text-white hover:bg-slate-800 shadow-xl transition\">\n            <Layers className=\"w-6 h-6\" />\n          </button>\n          <button className=\"bg-slate-900/90 backdrop-blur border border-slate-700 p-3 rounded-full text-slate-300 hover:text-white hover:bg-slate-800 shadow-xl transition\">\n            <Crosshair className=\"w-6 h-6\" />\n          </button>\n        </div>\n      </div>\n\n      {/* Map Content (Pins) */}\n      <div className=\"absolute inset-0 z-0 flex items-center justify-center\">\n        {/* Mock Pin 1 */}\n        <div className=\"absolute top-[40%] left-[30%]\">\n          <div className=\"relative group cursor-pointer\" onClick={() => setActiveIncident('INC-901')}>\n            <div className=\"w-12 h-12 bg-red-500 rounded-full flex items-center justify-center animate-pulse shadow-[0_0_20px_rgba(239,68,68,0.6)] border-2 border-white\">\n              <AlertCircle className=\"text-white w-6 h-6\" />\n            </div>\n            {/* Ping animation effect */}\n            <div className=\"absolute inset-0 border-4 border-red-500 rounded-full animate-ping opacity-50\"></div>\n          </div>\n        </div>\n      </div>\n\n      {/* Bottom Interface HUD */}\n      <div className=\"z-10 mt-auto p-4 pointer-events-none\">\n        {activeIncident && (\n          <div className=\"max-w-md w-full bg-slate-900/95 backdrop-blur border border-slate-700 rounded-2xl p-6 shadow-2xl pointer-events-auto transition-transform duration-300 translate-y-0\">\n            <div className=\"flex justify-between items-start mb-4\">\n              <div>\n                <span className=\"bg-red-500/20 text-red-400 px-2 py-1 rounded text-xs font-bold font-mono tracking-wider mb-2 inline-block\">CRITICAL</span>\n                <h3 className=\"text-xl font-bold text-white\">Mass Casualty Event</h3>\n              </div>\n              <p className=\"text-slate-400 text-sm\">{activeIncident}</p>\n            </div>\n            \n            <p className=\"text-slate-300 mb-6 line-clamp-2\">\n              Explosion reported at Main Concourse. Multiple casualties. Fire spreading to North Sector. Requesting immediate backup and EMTs.\n            </p>\n\n            <div className=\"grid grid-cols-2 gap-4\">\n              <button className=\"bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl flex items-center justify-center gap-2 transition\">\n                <Navigation className=\"w-5 h-5\" /> Navigate\n              </button>\n              <button className=\"bg-slate-800 hover:bg-slate-700 text-white font-bold py-3 rounded-xl flex items-center justify-center gap-2 transition border border-slate-600\">\n                <Info className=\"w-5 h-5\" /> Details\n              </button>\