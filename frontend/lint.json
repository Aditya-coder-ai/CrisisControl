 from MediaRecorder) into a base64 string\n * ready to be ingested by the Go backend's SyncService.\n */\nexport async function normalizeAudioInput(audioBlob: Blob): Promise<MultiModalPayload> {\n  const base64 = await blobToBase64(audioBlob);\n  return {\n    type: 'audio',\n    content: base64,\n    metadata: {\n      mimeType: audioBlob.type,\n      size: audioBlob.size,\n      timestamp: new Date().toISOString()\n    }\n  };\n}\n\n/**\n * Normalizes an image File/Blob for transport.\n * In a production environment, this would also include resizing/compression algorithms via canvas.\n */\nexport async function normalizeImageInput(imageFile: File): Promise<MultiModalPayload> {\n  const base64 = await blobToBase64(imageFile);\n  return {\n    type: 'image',\n    content: base64,\n    metadata: {\n      name: imageFile.name,\n      mimeType: imageFile.type,\n      size: imageFile.size,\n      timestamp: new Date().toISOString()\n    }\n  };\n}\n\n// Utility function to convert Blob/File to Base64\nfunction blobToBase64(blob: Blob): Promise<string> {\n  return new Promise((resolve, reject) => {\n    const reader = new FileReader();\n    reader.onloadend = () => {\n      if (typeof reader.result === 'string') {\n        const base64Content = reader.result.split(',')[1];\n        resolve(base64Content);\n      } else {\n        reject(new Error('Failed to convert blob to base64'));\n      }\n    };\n    reader.onerror = reject;\n    reader.readAsDataURL(blob);\n  });\n}\n","usedDeprecatedRules":[{"ruleId":"no-extra-semi","replacedBy":[]},{"ruleId":"no-mixed-spaces-and-tabs","replacedBy":[]}]},{"filePath":"C:\\Users\\ACER\\OneDrive\\Attachments\\Desktop\\Team\\frontend\\src\\main.tsx","messages":[{"ruleId":"react-refresh/only-export-components","message":"Definition for rule 'react-refresh/only-export-components' was not found.","line":1,"column":1,"endLine":1,"endColumn":2,"severity":2,"nodeType":null}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warnin