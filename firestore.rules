rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Incidents collection — allow read/write for authenticated demo
    match /incidents/{incidentId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Incident updates collection
    match /incident_updates/{updateId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
